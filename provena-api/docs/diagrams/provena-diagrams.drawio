        <mxCell id="l5" value="CANCELLED&#10;(release stock, refund)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8B84B;strokeColor=#1B2B1E;fontColor=#1B2B1E;" vertex="1" parent="1"><mxGeometry x="240" y="220" width="200" height="56" as="geometry" /></mxCell>
        <mxCell id="l6" value="Payout: net = gross - commission&#10;via Stripe Connect" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EAF2EC;strokeColor=#1B2B1E;fontColor=#1B2B1E;" vertex="1" parent="1"><mxGeometry x="700" y="220" width="240" height="56" as="geometry" /></mxCell>
        <mxCell id="l7" value="Return within 14 days?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FBF0D3;strokeColor=#7C6E5B;fontColor=#1B2B1E;" vertex="1" parent="1"><mxGeometry x="640" y="360" width="160" height="80" as="geometry" /></mxCell>
