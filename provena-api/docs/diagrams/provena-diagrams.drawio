  <diagram name="Order lifecycle" id="page-lifecycle">
    <mxGraphModel dx="900" dy="700" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1100" pageHeight="700" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="l1" value="PENDING" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EAF2EC;strokeColor=#1B2B1E;fontColor=#1B2B1E;" vertex="1" parent="1"><mxGeometry x="40" y="60" width="140" height="50" as="geometry" /></mxCell>
