# Copy this file to .env and fill in values for local development.
# Never commit .env to version control.

# Django
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Database (Docker Compose default)
DATABASE_URL=postgres://provena:provena@localhost:5432/provena

# Redis (Docker Compose default)
REDIS_URL=redis://localhost:6379/0

# Stripe (use test keys from https://dashboard.stripe.com/test/apikeys)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# File storage (leave blank to use local filesystem in development)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=eu-west-2

# Email (leave blank to use console backend in development)
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@provena.io

# Sentry (leave blank to disable error tracking in development)
SENTRY_DSN=

# Frontend URL (used in email links and CORS)
FRONTEND_URL=http://localhost:3000

# Production only
CORS_ALLOWED_ORIGINS=https://provena.io
